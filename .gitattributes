# Auto detect text files and perform LF normalization
* text=auto

# Force these to always be LF
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Binary files - no line ending changes
*.png binary
*.jpg binary
*.svg binary
*.ico binary
