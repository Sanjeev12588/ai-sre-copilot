  "components": {
    "schemas": {
      "AgentStatusResponse": {
        "properties": {
          "agent_name": {
            "type": "string",
            "title": "Agent Name",
            "description": "Unique name of the agent (e.g. LogAnalyzerAgent)."
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current execution state (IDLE, RUNNING, COMPLETED, FAILED)."
          },
          "last_active_at": {
            "type": "string",
            "title": "Last Active At",
            "description": "ISO-8601 UTC timestamp of the last agent activity."
          },
          "duration_ms": {
            "type": "integer",
            "title": "Duration Ms",
            "description": "Total wall-clock execution duration in milliseconds."
          },
          "tools_used": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tools Used",
            "description": "List of tools called by this agent."
          }
        },
        "type": "object",
        "required": [
          "agent_name",
          "status",
          "last_active_at",
          "duration_ms"
        ],
        "title": "AgentStatusResponse",
        "description": "Activity state of an individual agent in the incident pipeline.",
        "example": {
          "agent_name": "LogAnalyzerAgent",
          "duration_ms": 3200,
          "last_active_at": "2026-06-27T10:01:25Z",
          "status": "COMPLETED",
          "tools_used": [
            "query_logs"
          ]
        }
      },
      "ErrorDetailResponse": {
        "properties": {
          "error_code": {
            "type": "string",
            "title": "Error Code",
            "description": "Structured machine-readable error token (e.g. INCIDENT_NOT_FOUND)."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Detailed human-readable explanation of what went wrong."
          },
          "details": {
            "additionalProperties": true,
            "type": "object",
            "title": "Details",
            "description": "Contextual metadata or sub-errors."
          },
          "request_id": {
            "type": "string",
            "title": "Request Id",
            "description": "Trace identifier of the failed request."
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp",
            "description": "ISO-8601 UTC timestamp when the error was caught."
          }
        },
        "type": "object",
        "required": [
          "error_code",
          "message",
          "request_id",
          "timestamp"
        ],
        "title": "ErrorDetailResponse",
        "description": "Global standardized SRE API error response schema.",
        "example": {
          "details": {
            "incident_id": "INC-GHOST"
          },
          "error_code": "INCIDENT_NOT_FOUND",
          "message": "Incident INC-GHOST was not found in persistence.",
          "request_id": "4f17c982-8de3-4697-8267-eb3ec27fadcd",
          "timestamp": "2026-06-27T10:12:15.123456+00:00"
        }
      },
      "EvaluationResponse": {
        "properties": {
          "incident_id": {
            "type": "string",
            "title": "Incident Id",
            "description": "Target incident ID."
          },
          "verdict": {
            "type": "string",
            "title": "Verdict",
            "description": "Evaluation verdict (e.g. PASS, FAIL)."
          },
          "notes": {
            "type": "string",
